gcc -nostdlib -fPIC -Wl,--warn-common -Wl,--no-undefined -Wl,-shared -Wl,-Bsymbolic -L/usr/lib64 -L/root/kernelcare-certwrapper/gnu-efi/ -Wl,--build-id=sha1 -Wl,--hash-style=sysv  -o certwrapper.so certwrapper.o sbat_data.o  \
