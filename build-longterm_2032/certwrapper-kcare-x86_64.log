git submodule update --init --recursive
gcc -O0 -g3 -fPIC -Werror -Wall -Wextra -fshort-wchar -fno-merge-constants -ffreestanding -fno-stack-protector -fno-stack-check --std=gnu11 -DCONFIG_x86_64 -I/root/kernelcare-certwrapper/gnu-efi//inc -I/root/kernelcare-certwrapper/gnu-efi//inc/x86_64 -I/root/kernelcare-certwrapper/gnu-efi//inc/protocol -mno-mmx -mno-sse -mno-red-zone -nostdinc -maccumulate-outgoing-args -DEFI_FUNCTION_WRAPPER -DGNU_EFI_USE_MS_ABI -I/usr/lib/gcc/x86_64-redhat-linux/11/include -DVENDOR_DB -c -o certwrapper.o certwrapper.c
gcc -O0 -g3 -fPIC -Werror -Wall -Wextra -fshort-wchar -fno-merge-constants -ffreestanding -fno-stack-protector -fno-stack-check --std=gnu11 -DCONFIG_x86_64 -I/root/kernelcare-certwrapper/gnu-efi//inc -I/root/kernelcare-certwrapper/gnu-efi//inc/x86_64 -I/root/kernelcare-certwrapper/gnu-efi//inc/protocol -mno-mmx -mno-sse -mno-red-zone -nostdinc -maccumulate-outgoing-args -DEFI_FUNCTION_WRAPPER -DGNU_EFI_USE_MS_ABI -I/usr/lib/gcc/x86_64-redhat-linux/11/include -DVENDOR_DB -x c -c -o sbat_data.o /dev/null
